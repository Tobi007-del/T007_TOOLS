{
  "name": "sia-reactor",
  "version": "0.0.9",
  "description": "The Programmable Data DOM. A high-performance State Intent Architecture (S.I.A.) Engine with zero-allocation loops, event propagation, and structural sharing.",
  "author": "Oketade Oluwatobiloba <tobioketade007@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tobi007-del/t007-tools.git",
    "directory": "packages/sia-reactor"
  },
  "homepage": "https://github.com/Tobi007-del/tree/main/packages/sia-reactor#readme",
  "bugs": {
    "url": "https://github.com/Tobi007-del/sia-reactor/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "browser": "./dist/index.global.js",
  "unpkg": "./dist/index.global.js",
  "jsdelivr": "./dist/index.global.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "import": "./dist/utils.js",
      "require": "./dist/utils.cjs",
      "default": "./dist/utils.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs",
      "default": "./dist/react.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts src/utils.ts src/react.ts --format cjs,esm,iife --global-name sia --dts --clean",
    "prepublishOnly": "shx cp ../../LICENSE ."
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "t007",
    "ecosystem",
    "reactor",
    "sia",
    "state",
    "intent",
    "architecture",
    "engine",
    "event",
    "propagation",
    "state-management",
    "reactive",
    "proxy",
    "events",
    "data-dom",
    "structural-sharing",
    "performance"
  ],
  "devDependencies": {
    "@types/react": "^18.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "react": "^18.0.0"
  }
}
