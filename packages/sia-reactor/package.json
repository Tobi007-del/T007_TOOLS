{
  "name": "sia-reactor",
  "version": "0.0.22",
  "description": "The Programmable Data DOM. A high-performance State Intent Architecture (S.I.A.) Engine with zero-allocation loops, event propagation, and structural sharing.",
  "author": "Oketade Oluwatobiloba <tobioketade007@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tobi007-del/t007-tools.git",
    "directory": "packages/sia-reactor"
  },
  "homepage": "https://github.com/Tobi007-del/tree/main/packages/sia-reactor#readme",
  "bugs": {
    "url": "https://github.com/Tobi007-del/sia-reactor/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "unpkg": "./dist/super.global.js",
  "jsdelivr": "./dist/super.global.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "import": "./dist/utils.js",
      "require": "./dist/utils.cjs",
      "default": "./dist/utils.js"
    },
    "./modules": {
      "types": "./dist/modules.d.ts",
      "import": "./dist/modules.js",
      "require": "./dist/modules.cjs",
      "default": "./dist/modules.js"
    },
    "./adapters/vanilla": {
      "types": "./dist/adapters/vanilla.d.ts",
      "import": "./dist/adapters/vanilla.js",
      "require": "./dist/adapters/vanilla.cjs",
      "default": "./dist/adapters/vanilla.js"
    },
    "./adapters/react": {
      "types": "./dist/adapters/react.d.ts",
      "import": "./dist/adapters/react.js",
      "require": "./dist/adapters/react.cjs",
      "default": "./dist/adapters/react.js"
    },
    "./styles/time-travel-overlay.css": "./dist/styles/time-travel-overlay.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "prepublishOnly": "shx cp ../../LICENSE .",
    "test": "vitest --reporter=verbose",
    "test:run": "vitest run",
    "demo": "vite --config demo/vite.config.ts",
    "demo:build": "vite build --config demo/vite.config.ts",
    "demo:preview": "vite preview --config demo/vite.config.ts"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "t007",
    "ecosystem",
    "reactor",
    "sia",
    "state",
    "intent",
    "architecture",
    "engine",
    "event",
    "propagation",
    "state-management",
    "reactive",
    "proxy",
    "events",
    "data-dom",
    "structural-sharing",
    "performance",
    "zero-dependency"
  ],
  "devDependencies": {
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^5.0.4",
    "@types/react": "^18.0.0",
    "happy-dom": "^20.8.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "react": "^18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  }
}
